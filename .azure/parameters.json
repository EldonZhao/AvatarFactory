{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "resourceGroup": {
            "value": "avatarfactory-rg"
        },
        "location": {
            "value": "eastasia"
        },
        "appName": {
            "value": "avatarfactory-app"
        },
        "sku": {
            "value": "B1",
            "metadata": {
                "description": "App Service Plan SKU. Options: F1 (free), B1, B2, B3, S1, S2, S3, P1v2, P2v2, P3v2"
            }
        },
        "llmProvider": {
            "value": "anthropic",
            "metadata": {
                "description": "LLM provider: anthropic, openai, or azure_openai"
            }
        },
        "llmModel": {
            "value": "claude-3-5-sonnet-20241022",
            "metadata": {
                "description": "Model name for the LLM provider"
            }
        },
        "enableDashboard": {
            "value": true,
            "metadata": {
                "description": "Whether to enable the Streamlit dashboard alongside the API"
            }
        },
        "platforms": {
            "value": ["bluesky"],
            "metadata": {
                "description": "List of platforms to configure. Credentials must be set separately."
            }
        }
    }
}
