# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Choose your LLM provider (anthropic | azure_openai | openai)
AVATARFACTORY_LLM_PROVIDER=anthropic

# Model name (provider-specific)
AVATARFACTORY_MODEL=claude-3-5-sonnet-20241022
AVATARFACTORY_FAST_MODEL=claude-3-5-haiku-20241022

# -----------------------------------------------------------------------------
# Option 1: Anthropic Claude (Default)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here

# -----------------------------------------------------------------------------
# Option 2: Azure OpenAI
# -----------------------------------------------------------------------------
# AVATARFACTORY_LLM_PROVIDER=azure_openai
# AVATARFACTORY_MODEL=gpt-4
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# Option 3: OpenAI
# -----------------------------------------------------------------------------
# AVATARFACTORY_LLM_PROVIDER=openai
# AVATARFACTORY_MODEL=gpt-4-turbo-preview
# OPENAI_API_KEY=your_openai_key_here

# =============================================================================
# Social Platform Connectors
# =============================================================================

# -----------------------------------------------------------------------------
# Bluesky (AT Protocol) - Recommended for getting started
# -----------------------------------------------------------------------------
# BLUESKY_USERNAME=your.handle.bsky.social
# BLUESKY_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Twitter/X API v2
# -----------------------------------------------------------------------------
# TWITTER_API_KEY=your_api_key
# TWITTER_API_SECRET=your_api_secret
# TWITTER_ACCESS_TOKEN=your_bearer_token
# TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# -----------------------------------------------------------------------------
# Xiaohongshu (小红书) - Cookie-based authentication
# -----------------------------------------------------------------------------
# Get cookie from browser DevTools after logging in to xiaohongshu.com
# XIAOHONGSHU_COOKIE=your_full_cookie_string
# XIAOHONGSHU_USER_ID=your_user_id (optional)
# XIAOHONGSHU_B1=your_b1_value (from localStorage, required for API signing)
#
# To get b1: DevTools -> Application -> Local Storage -> xiaohongshu.com -> b1

# =============================================================================
# Video Generation
# =============================================================================

# TTS Provider: auto | azure | edge
# - auto: Uses Azure if configured, falls back to Edge (free)
# - azure: Azure Cognitive Services Speech (requires API key)
# - edge: Microsoft Edge TTS (free, no API key required)
AVATARFACTORY_VIDEO_PROVIDER=auto

# Azure Speech Service (for Azure TTS and Avatar)
# Get your key from: https://portal.azure.com -> Cognitive Services -> Speech
# AZURE_SPEECH_KEY=your_azure_speech_key
# AZURE_SPEECH_REGION=eastasia

# Available regions for Azure Speech:
# - TTS only: eastasia, eastus, westeurope, etc.
# - Avatar support: westus2, westeurope, southeastasia

# Default TTS voice for video generation
AVATARFACTORY_DEFAULT_VOICE=zh-CN-XiaoxuanNeural

# =============================================================================
# Other Configuration
# =============================================================================

# Knowledges Path
AVATARFACTORY_KB_PATH=./knowledges

# Logging
AVATARFACTORY_LOG_LEVEL=INFO

# =============================================================================
# Scheduler & Notifications (Optional)
# =============================================================================

# Enable background scheduler
# AVATARFACTORY_SCHEDULER_ENABLED=true

# Service URL for notifications (used for content view links in WeChat Work)
# AVATARFACTORY_SERVICE_URL=http://localhost:8000

# Default schedules (cron format: minute hour day month day_of_week)
# AVATARFACTORY_DISCOVERY_SCHEDULE=0 9 * * *
# AVATARFACTORY_CONTENT_SCHEDULE=0 10 * * *
# AVATARFACTORY_PUBLISH_SCHEDULE=0 12,18 * * *
# AVATARFACTORY_REPORT_SCHEDULE=0 18 * * 5

# Webhook Notifications (choose one format)
# AVATARFACTORY_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# AVATARFACTORY_WEBHOOK_FORMAT=slack

# Supported formats: generic, slack, discord, feishu, wecom
