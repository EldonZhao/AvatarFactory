# =============================================================================
# Local Development Ports (DO NOT CHANGE)
# =============================================================================
# These ports are used by all local services. Changing them requires updating
# multiple configuration files across the project.
#
# Service                Port    Description
# ---------------------  ------  ----------------------------------------
# AvatarFactory API      8000    Backend FastAPI service
# Web Admin              4323    Admin dashboard (Astro)
# Monitor                4321    Monitoring dashboard
# Journal                4328    Journal service
# Streamlit Dashboard    8501    Legacy Streamlit dashboard (optional)
#
# To start services locally:
#   avatarfactory serve --port 8000     # Backend API
#   cd web-admin && npm run dev          # Web Admin (port 4323)

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Choose your LLM provider (anthropic | azure_openai | openai)
AVATARFACTORY_LLM_PROVIDER=anthropic

# Model name (provider-specific)
AVATARFACTORY_MODEL=claude-3-5-sonnet-20241022
AVATARFACTORY_FAST_MODEL=claude-3-5-haiku-20241022

# -----------------------------------------------------------------------------
# Option 1: Anthropic Claude (Default)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here

# -----------------------------------------------------------------------------
# Option 2: Azure OpenAI
# -----------------------------------------------------------------------------
# AVATARFACTORY_LLM_PROVIDER=azure_openai
# AVATARFACTORY_MODEL=gpt-4
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# Option 3: OpenAI
# -----------------------------------------------------------------------------
# AVATARFACTORY_LLM_PROVIDER=openai
# AVATARFACTORY_MODEL=gpt-4-turbo-preview
# OPENAI_API_KEY=your_openai_key_here

# =============================================================================
# Social Platform Connectors
# =============================================================================

# -----------------------------------------------------------------------------
# Bluesky (AT Protocol) - Recommended for getting started
# -----------------------------------------------------------------------------
# BLUESKY_USERNAME=your.handle.bsky.social
# BLUESKY_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Twitter/X API v2
# -----------------------------------------------------------------------------
# TWITTER_API_KEY=your_api_key
# TWITTER_API_SECRET=your_api_secret
# TWITTER_ACCESS_TOKEN=your_bearer_token
# TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# -----------------------------------------------------------------------------
# Xiaohongshu (小红书) - Cookie-based authentication
# -----------------------------------------------------------------------------
# Get cookie from browser DevTools after logging in to xiaohongshu.com
# XIAOHONGSHU_COOKIE=your_full_cookie_string
# XIAOHONGSHU_USER_ID=your_user_id (optional)
# XIAOHONGSHU_B1=your_b1_value (from localStorage, required for API signing)
#
# To get b1: DevTools -> Application -> Local Storage -> xiaohongshu.com -> b1

# -----------------------------------------------------------------------------
# LinkedIn - OAuth 2.0
# -----------------------------------------------------------------------------
# Get credentials from: https://www.linkedin.com/developers/apps
# LINKEDIN_ACCESS_TOKEN=your_access_token
# LINKEDIN_CLIENT_ID=your_client_id
# LINKEDIN_CLIENT_SECRET=your_client_secret
# LINKEDIN_ORGANIZATION_ID=your_organization_id (optional, for company pages)

# -----------------------------------------------------------------------------
# Threads (Meta) - Graph API
# -----------------------------------------------------------------------------
# Get credentials from: https://developers.facebook.com/
# THREADS_ACCESS_TOKEN=your_access_token
# THREADS_USER_ID=your_threads_user_id

# -----------------------------------------------------------------------------
# Instagram Business - Graph API
# -----------------------------------------------------------------------------
# Get credentials from: https://developers.facebook.com/
# Requires a Business or Creator account connected to a Facebook Page
# INSTAGRAM_ACCESS_TOKEN=your_access_token
# INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# -----------------------------------------------------------------------------
# Weibo (微博) - OAuth 2.0
# -----------------------------------------------------------------------------
# Get credentials from: https://open.weibo.com/
# WEIBO_ACCESS_TOKEN=your_access_token
# WEIBO_UID=your_user_id
# WEIBO_APP_KEY=your_app_key (optional)

# -----------------------------------------------------------------------------
# Mastodon - Works with any instance
# -----------------------------------------------------------------------------
# Get access token from: Your Instance -> Preferences -> Development -> New Application
# MASTODON_ACCESS_TOKEN=your_access_token
# MASTODON_INSTANCE_URL=https://mastodon.social (or your instance URL)

# -----------------------------------------------------------------------------
# Toutiao (今日头条/头条号) - OAuth 2.0
# -----------------------------------------------------------------------------
# Get credentials from: https://open.mp.toutiao.com/
# TOUTIAO_ACCESS_TOKEN=your_access_token

# =============================================================================
# Video Generation
# =============================================================================

# TTS Provider: auto | azure | edge
# - auto: Uses Azure if configured, falls back to Edge (free)
# - azure: Azure Cognitive Services Speech (requires API key)
# - edge: Microsoft Edge TTS (free, no API key required)
AVATARFACTORY_VIDEO_PROVIDER=auto

# Azure Speech Service (for Azure TTS and Avatar)
# Get your key from: https://portal.azure.com -> Cognitive Services -> Speech
# AZURE_SPEECH_KEY=your_azure_speech_key
# AZURE_SPEECH_REGION=eastasia

# Available regions for Azure Speech:
# - TTS only: eastasia, eastus, westeurope, etc.
# - Avatar support: westus2, westeurope, southeastasia

# Default TTS voice for video generation
AVATARFACTORY_DEFAULT_VOICE=zh-CN-XiaoxuanNeural

# =============================================================================
# Other Configuration
# =============================================================================

# Knowledges Path
AVATARFACTORY_KB_PATH=./knowledges

# =============================================================================
# Database Configuration (Optional)
# =============================================================================
# By default, AvatarFactory uses file-based storage (YAML/JSON).
# Set AVATARFACTORY_USE_DB=true to use SQLite/PostgreSQL database instead.

# Enable database storage (default: false, uses file-based storage)
# AVATARFACTORY_USE_DB=true

# Database URL (optional, defaults to SQLite in knowledges directory)
# For SQLite (default):
# AVATARFACTORY_DB_URL=sqlite+aiosqlite:///./knowledges/avatarfactory.db
#
# For PostgreSQL:
# AVATARFACTORY_DB_URL=postgresql://user:password@localhost:5432/avatarfactory

# Database connection pool settings (PostgreSQL only)
# AVATARFACTORY_DB_POOL_SIZE=5
# AVATARFACTORY_DB_MAX_OVERFLOW=10
# AVATARFACTORY_DB_POOL_TIMEOUT=30
# AVATARFACTORY_DB_POOL_RECYCLE=1800

# Enable SQL query logging (for debugging)
# AVATARFACTORY_DB_ECHO=true

# Logging
AVATARFACTORY_LOG_LEVEL=INFO

# =============================================================================
# Scheduler & Notifications (Optional)
# =============================================================================

# Enable background scheduler
# AVATARFACTORY_SCHEDULER_ENABLED=true

# Service URL for notifications (used for content view links in WeChat Work)
# AVATARFACTORY_SERVICE_URL=http://localhost:8000

# Default schedules (cron format: minute hour day month day_of_week)
# AVATARFACTORY_DISCOVERY_SCHEDULE=0 9 * * *
# AVATARFACTORY_CONTENT_SCHEDULE=0 10 * * *
# AVATARFACTORY_PUBLISH_SCHEDULE=0 12,18 * * *
# AVATARFACTORY_REPORT_SCHEDULE=0 18 * * 5

# Webhook Notifications (system-level configuration)
# This URL is used for all personas with notifications enabled
# AVATARFACTORY_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
# AVATARFACTORY_WEBHOOK_FORMAT=wecom

# Supported formats: generic, slack, discord, feishu, wecom

# =============================================================================
# Multi-Tenancy (Optional)
# =============================================================================

# Admin API key for tenant management endpoints
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# AVATARFACTORY_ADMIN_KEY=your_admin_key_here

# Master encryption key for tenant credentials (Fernet key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# AVATARFACTORY_MASTER_KEY=your_fernet_key_here
