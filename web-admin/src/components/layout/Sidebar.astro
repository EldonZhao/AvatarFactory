---
const pathname = Astro.url.pathname;
// Ensure base starts with / and doesn't end with /
const rawBase = import.meta.env.BASE_URL || '';
const base = rawBase === '/' ? '' : (rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase);

// Build href with explicit leading slash
function buildHref(path: string): string {
  if (base) {
    return `${base}${path}`;
  }
  return path;
}

const navItems = [
  { href: buildHref('/'), label: 'Dashboard', icon: 'home' },
  { href: buildHref('/chat'), label: 'Chat', icon: 'message' },
  { href: buildHref('/personas'), label: 'Personas', icon: 'users' },
  { href: buildHref('/connectors'), label: 'Connectors', icon: 'link' },
  { href: buildHref('/schedulers'), label: 'Schedulers', icon: 'clock' },
  { href: buildHref('/topics'), label: 'Topics', icon: 'trending' },
  { href: buildHref('/contents'), label: 'Contents', icon: 'file-text' },
  { href: buildHref('/stats'), label: 'Statistics', icon: 'chart' },
];

function isActive(href: string): boolean {
  const homeHref = buildHref('/');
  if (href === homeHref) return pathname === homeHref || pathname === '/' || pathname === '';
  return pathname.startsWith(href);
}
---

<aside class="w-64 border-r border-[hsl(var(--border))] bg-[hsl(var(--card))] hidden lg:block">
  <div class="p-6">
    <a href={buildHref('/')} class="flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center shadow-lg group-hover:shadow-blue-500/25 transition-shadow">
        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
        </svg>
      </div>
      <div>
        <h1 class="font-bold text-lg gradient-text">Avatar Admin</h1>
        <p class="text-xs text-[hsl(var(--muted-foreground))]">Management Dashboard</p>
      </div>
    </a>
  </div>

  <nav class="px-3 pb-6">
    <ul class="space-y-1">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all',
              isActive(item.href)
                ? 'bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] shadow-md'
                : 'text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] hover:bg-[hsl(var(--accent))]'
            ]}
          >
            {item.icon === 'home' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            )}
            {item.icon === 'message' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            )}
            {item.icon === 'users' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            )}
            {item.icon === 'file-text' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            )}
            {item.icon === 'clock' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {item.icon === 'trending' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            )}
            {item.icon === 'chart' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            )}
            {item.icon === 'link' && (
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            )}
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="px-3 pb-6">
    <div class="p-4 rounded-xl bg-gradient-to-br from-blue-500/10 to-purple-500/10 border border-blue-500/20">
      <p class="text-xs text-[hsl(var(--muted-foreground))] mb-2">API Endpoint</p>
      <p class="text-sm font-medium">/api/*</p>
    </div>
  </div>
</aside>
