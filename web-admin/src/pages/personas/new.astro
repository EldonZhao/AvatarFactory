---
import AdminLayout from '../../layouts/AdminLayout.astro';

// Remove trailing slash from BASE_URL for consistent path joining
const rawBase = import.meta.env.BASE_URL || '';
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<AdminLayout title="创建 Persona">
  <div class="space-y-6 animate-fade-in">
    <!-- Header -->
    <div class="flex items-center gap-4">
      <a
        href={`${base}/personas`}
        class="p-2 rounded-lg hover:bg-[hsl(var(--accent))] transition-colors"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <div>
        <h1 class="text-2xl font-bold gradient-text">创建 Persona</h1>
        <p class="text-[hsl(var(--muted-foreground))] text-sm mt-1">
          配置新的 AI 人设
        </p>
      </div>
    </div>

    <!-- Form -->
    <div class="p-6 rounded-xl bg-[hsl(var(--card))] border border-[hsl(var(--border))]">
      <form id="create-persona-form" class="space-y-6">
        <!-- Basic Info -->
        <div class="space-y-4">
          <h2 class="text-lg font-semibold">基本信息</h2>

          <div>
            <label class="block text-sm text-[hsl(var(--muted-foreground))] mb-1">名称 *</label>
            <input
              type="text"
              name="name"
              required
              class="w-full px-4 py-2 rounded-lg bg-[hsl(var(--accent))] border border-[hsl(var(--border))] focus:outline-none focus:ring-2 focus:ring-[hsl(var(--primary))]"
              placeholder="例如：科技博主小明"
            />
          </div>

          <div>
            <label class="block text-sm text-[hsl(var(--muted-foreground))] mb-1">标语</label>
            <input
              type="text"
              name="tagline"
              class="w-full px-4 py-2 rounded-lg bg-[hsl(var(--accent))] border border-[hsl(var(--border))] focus:outline-none focus:ring-2 focus:ring-[hsl(var(--primary))]"
              placeholder="一句话描述人设特点"
            />
          </div>

          <div>
            <label class="block text-sm text-[hsl(var(--muted-foreground))] mb-1">描述 *</label>
            <textarea
              name="description"
              required
              rows="4"
              class="w-full px-4 py-2 rounded-lg bg-[hsl(var(--accent))] border border-[hsl(var(--border))] focus:outline-none focus:ring-2 focus:ring-[hsl(var(--primary))] resize-none"
              placeholder="详细描述人设的背景、性格、专业领域等"
            ></textarea>
          </div>
        </div>

        <!-- Platforms -->
        <div class="space-y-4">
          <h2 class="text-lg font-semibold">目标平台</h2>
          <div class="flex flex-wrap gap-3">
            {['xiaohongshu', 'bluesky', 'twitter', 'linkedin', 'threads'].map((platform) => (
              <label class="flex items-center gap-2 px-4 py-2 rounded-lg bg-[hsl(var(--accent))] cursor-pointer hover:bg-[hsl(var(--accent))]/80 transition-colors">
                <input type="checkbox" name="platforms" value={platform} class="rounded" />
                <span class="text-sm">{platform}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- Expertise -->
        <div class="space-y-4">
          <h2 class="text-lg font-semibold">专业领域</h2>
          <div>
            <label class="block text-sm text-[hsl(var(--muted-foreground))] mb-1">专业领域（用逗号分隔）</label>
            <input
              type="text"
              name="expertise"
              class="w-full px-4 py-2 rounded-lg bg-[hsl(var(--accent))] border border-[hsl(var(--border))] focus:outline-none focus:ring-2 focus:ring-[hsl(var(--primary))]"
              placeholder="例如：人工智能, 科技评测, 数码产品"
            />
          </div>
        </div>

        <!-- Actions -->
        <div class="flex gap-4 pt-4">
          <button
            type="submit"
            class="px-6 py-2 rounded-lg bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] hover:opacity-90 transition-opacity font-medium"
          >
            创建 Persona
          </button>
          <a
            href={`${base}/personas`}
            class="px-6 py-2 rounded-lg bg-[hsl(var(--secondary))] text-[hsl(var(--secondary-foreground))] hover:opacity-90 transition-opacity font-medium"
          >
            取消
          </a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<!-- Hidden element to pass base URL to client script -->
<div id="app-config" data-base-url={base} style="display:none;"></div>

<script>
  const baseUrl = document.getElementById('app-config')?.dataset.baseUrl || '';
  const form = document.getElementById('create-persona-form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form as HTMLFormElement);
    const platforms = formData.getAll('platforms');
    const expertiseStr = formData.get('expertise') as string;
    const expertise = expertiseStr ? expertiseStr.split(',').map(s => s.trim()).filter(Boolean) : [];

    const data = {
      name: formData.get('name'),
      tagline: formData.get('tagline') || undefined,
      description: formData.get('description'),
      platforms,
      expertise,
    };

    try {
      const response = await fetch('/api/admin/personas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        const result = await response.json();
        window.location.href = `${baseUrl}/personas/${result.id || ''}`;
      } else {
        alert('创建失败: ' + response.statusText);
      }
    } catch (err) {
      alert('创建失败: ' + err);
    }
  });
</script>
