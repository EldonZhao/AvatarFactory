---
import AdminLayout from '../../layouts/AdminLayout.astro';

const API_BASE = import.meta.env.API_BASE_URL || import.meta.env.ADMIN_API_BASE || 'http://127.0.0.1:8000';
// Remove trailing slash from BASE_URL for consistent path joining
const rawBase = import.meta.env.BASE_URL || '';
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

// Get cookie from request for SSR authentication
const cookie = Astro.request.headers.get('cookie') || '';

let tasksData: any = null;
let schedulerStatus: any = null;
let error = null;

try {
  const [tasksResponse, statusResponse] = await Promise.all([
    fetch(`${API_BASE}/api/admin/scheduler/tasks`, {
      headers: { 'Cookie': cookie }
    }),
    fetch(`${API_BASE}/scheduler/status`),
  ]);

  if (tasksResponse.ok) {
    tasksData = await tasksResponse.json();
  }
  if (statusResponse.ok) {
    schedulerStatus = await statusResponse.json();
  }
} catch (e) {
  error = `Failed to fetch: ${e}`;
}

const grouped = tasksData?.grouped || {};
const taskCount = tasksData?.count || 0;

// Filter out system tasks - they are shown on Connectors page now
const personaIds = Object.keys(grouped).filter(k => k !== 'system');

// Calculate total run count from persona tasks only (exclude system)
let totalRunCount = 0;
personaIds.forEach((personaId) => {
  grouped[personaId]?.tasks?.forEach((task: any) => {
    totalRunCount += task.run_count || 0;
  });
});

// Calculate task count excluding system tasks
const personaTaskCount = personaIds.reduce((sum, id) => sum + (grouped[id]?.tasks?.length || 0), 0);
---

<AdminLayout title="Schedulers">
  <div class="space-y-6 animate-fade-in">
    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold gradient-text">Schedulers</h1>
        <p class="text-[hsl(var(--muted-foreground))] text-sm mt-1">
          管理定时任务
        </p>
      </div>
      <div class="flex items-center gap-4">
        <a
          href={`${base}/schedulers/new`}
          class="px-4 py-2 rounded-lg bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] hover:opacity-90 transition-opacity text-sm font-medium"
        >
          创建任务
        </a>
      </div>
    </div>

    {error ? (
      <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-600 dark:text-red-400">
        <p class="font-medium">无法加载数据</p>
        <p class="text-sm mt-1">{error}</p>
      </div>
    ) : (
      <>
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="rounded-xl border bg-[hsl(var(--card))] border-[hsl(var(--border))] overflow-hidden">
            <div class="p-6">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm text-[hsl(var(--muted-foreground))] mb-1">总任务数</p>
                  <p class="text-3xl font-bold text-[hsl(var(--foreground))]">{personaTaskCount}</p>
                </div>
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center text-white shadow-lg">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <div class="rounded-xl border bg-[hsl(var(--card))] border-[hsl(var(--border))] overflow-hidden">
            <div class="p-6">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm text-[hsl(var(--muted-foreground))] mb-1">Personas</p>
                  <p class="text-3xl font-bold text-[hsl(var(--foreground))]">{personaIds.length}</p>
                </div>
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white shadow-lg">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <div class="rounded-xl border bg-[hsl(var(--card))] border-[hsl(var(--border))] overflow-hidden">
            <div class="p-6">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm text-[hsl(var(--muted-foreground))] mb-1">总运行次数</p>
                  <p class="text-3xl font-bold text-[hsl(var(--foreground))]">{totalRunCount}</p>
                </div>
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center text-white shadow-lg">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tasks by Persona -->
        {personaIds.length > 0 ? (
          <div class="space-y-6">
            {personaIds.map((personaId) => {
              const data = grouped[personaId];
              return (
              <div class="p-6 rounded-xl bg-[hsl(var(--card))] border border-[hsl(var(--border))]">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold">
                      {data.persona_name.charAt(0)}
                    </div>
                    <div>
                      <h2 class="font-semibold">{data.persona_name}</h2>
                      <p class="text-xs text-[hsl(var(--muted-foreground))]">{data.tasks.length} 个任务</p>
                    </div>
                  </div>
                  <a
                    href={`${base}/personas/${personaId}`}
                    class="text-sm text-[hsl(var(--primary))] hover:underline"
                  >
                    查看 Persona →
                  </a>
                </div>

                <div class="space-y-3">
                  {data.tasks.map((task: any) => (
                    <div class="p-4 rounded-lg bg-[hsl(var(--accent))]">
                      <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                          <div class="flex items-center gap-2 mb-1">
                            <span class={`w-2 h-2 rounded-full ${task.enabled ? 'bg-green-500' : 'bg-gray-400'}`}></span>
                            <span class="font-medium">{task.name}</span>
                            <span class={`text-xs px-2 py-0.5 rounded ${task.enabled ? 'bg-green-500/10 text-green-600' : 'bg-gray-500/10 text-gray-500'}`}>
                              {task.enabled ? '启用' : '禁用'}
                            </span>
                          </div>
                          <div class="flex flex-wrap gap-2 text-xs text-[hsl(var(--muted-foreground))]">
                            <span class="px-2 py-0.5 rounded bg-[hsl(var(--card))]">
                              {task.task_type}
                            </span>
                            <span class="px-2 py-0.5 rounded bg-[hsl(var(--card))]">
                              {task.schedule}
                            </span>
                            {task.platform && (
                              <span class="px-2 py-0.5 rounded bg-[hsl(var(--primary))]/10 text-[hsl(var(--primary))]">
                                {task.platform}
                              </span>
                            )}
                            {task.run_count !== undefined && task.run_count > 0 && (
                              <span class="px-2 py-0.5 rounded bg-blue-500/10 text-blue-600">
                                已运行 {task.run_count} 次
                              </span>
                            )}
                          </div>
                          {task.last_run && (
                            <p class="text-xs text-[hsl(var(--muted-foreground))] mt-2">
                              上次运行: {new Date(task.last_run).toLocaleString('zh-CN')}
                              {task.last_status && (
                                <span class={`ml-2 ${task.last_status === 'success' ? 'text-green-500' : 'text-red-500'}`}>
                                  ({task.last_status})
                                </span>
                              )}
                              {task.last_error && (
                                <span class="ml-2 text-red-500">- {task.last_error}</span>
                              )}
                            </p>
                          )}
                          {task.next_run_time && (
                            <p class="text-xs text-[hsl(var(--muted-foreground))] mt-1">
                              <span class="text-green-600">下次运行:</span> {new Date(task.next_run_time).toLocaleString('zh-CN')}
                            </p>
                          )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )})}
          </div>
        ) : (
          <div class="p-12 rounded-xl bg-[hsl(var(--card))] border border-[hsl(var(--border))] text-center">
            <div class="w-16 h-16 rounded-full bg-[hsl(var(--muted))] flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-[hsl(var(--muted-foreground))]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-2">暂无计划任务</h3>
            <p class="text-[hsl(var(--muted-foreground))] mb-4">
              为 Persona 配置定时任务开始自动化
            </p>
          </div>
        )}
      </>
    )}
  </div>
</AdminLayout>
