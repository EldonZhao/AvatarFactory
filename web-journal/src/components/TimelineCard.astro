---
import type { TimelineEvent } from '../lib/types';

interface Props {
  event: TimelineEvent;
}

const { event } = Astro.props;

// Event type to color/icon mapping
const eventConfig: Record<string, { color: string; bgColor: string; label: string }> = {
  persona_created: { color: 'text-green-500', bgColor: 'bg-green-500/10', label: '人设创建' },
  persona_updated: { color: 'text-green-500', bgColor: 'bg-green-500/10', label: '人设更新' },
  content_created: { color: 'text-blue-500', bgColor: 'bg-blue-500/10', label: '内容创建' },
  content_published: { color: 'text-purple-500', bgColor: 'bg-purple-500/10', label: '内容发布' },
  review_completed: { color: 'text-pink-500', bgColor: 'bg-pink-500/10', label: '审核完成' },
  task_scheduled: { color: 'text-amber-500', bgColor: 'bg-amber-500/10', label: '任务调度' },
  task_executed: { color: 'text-amber-500', bgColor: 'bg-amber-500/10', label: '任务执行' },
};

const config = eventConfig[event.type] || { color: 'text-blue-500', bgColor: 'bg-blue-500/10', label: '事件' };

const timeStr = new Date(event.timestamp).toLocaleTimeString('zh-CN', {
  hour: '2-digit',
  minute: '2-digit',
});

// Generate unique ID for this card
const cardId = `event-${event.id}`;
---

<div class="bg-[hsl(var(--card))] border border-[hsl(var(--border))] rounded-xl overflow-hidden">
  <!-- Header - Always visible, clickable to expand -->
  <button
    class="w-full text-left p-4 hover:bg-[hsl(var(--accent))] transition-colors cursor-pointer"
    data-expand-btn={cardId}
    aria-expanded="false"
  >
    <div class="flex items-start gap-3">
      <div class={`w-10 h-10 rounded-lg ${config.bgColor} flex items-center justify-center flex-shrink-0`}>
        {event.type.includes('persona') && (
          <svg class={`w-5 h-5 ${config.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        )}
        {event.type.includes('content') && (
          <svg class={`w-5 h-5 ${config.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        )}
        {event.type.includes('review') && (
          <svg class={`w-5 h-5 ${config.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        )}
        {event.type.includes('task') && (
          <svg class={`w-5 h-5 ${config.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        )}
      </div>

      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1 flex-wrap">
          <span class={`text-xs px-2 py-0.5 rounded-full ${config.bgColor} ${config.color} font-medium`}>
            {config.label}
          </span>
          <span class="text-xs text-[hsl(var(--muted-foreground))]">{timeStr}</span>
          {event.persona_name && (
            <span class="text-xs text-[hsl(var(--muted-foreground))]">· {event.persona_name}</span>
          )}
        </div>
        <h3 class="font-semibold">{event.title}</h3>
        <p class="text-sm text-[hsl(var(--muted-foreground))] line-clamp-2 mt-1">{event.description}</p>
      </div>

      <!-- Expand icon -->
      <svg
        class="w-5 h-5 text-[hsl(var(--muted-foreground))] flex-shrink-0 transition-transform duration-200"
        data-expand-icon={cardId}
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </button>

  <!-- Expandable content -->
  <div
    class="hidden border-t border-[hsl(var(--border))] bg-[hsl(var(--muted))/0.3]"
    data-expand-content={cardId}
  >
    <div class="p-4 space-y-4">
      <!-- Full description -->
      <div>
        <h4 class="text-sm font-medium text-[hsl(var(--muted-foreground))] mb-2">详细内容</h4>
        <p class="text-sm leading-relaxed">{event.description}</p>
      </div>

      <!-- Metadata if available -->
      {event.metadata && Object.keys(event.metadata).length > 0 && (
        <div>
          <h4 class="text-sm font-medium text-[hsl(var(--muted-foreground))] mb-2">事件详情</h4>
          <dl class="grid grid-cols-2 gap-2 text-sm">
            {Object.entries(event.metadata).map(([key, value]) => (
              <div class="flex flex-col">
                <dt class="text-[hsl(var(--muted-foreground))] text-xs">{key}</dt>
                <dd class="font-medium">{String(value)}</dd>
              </div>
            ))}
          </dl>
        </div>
      )}

      <!-- Content preview for content events -->
      {event.content && (
        <div>
          <h4 class="text-sm font-medium text-[hsl(var(--muted-foreground))] mb-2">内容预览</h4>
          <div class="bg-[hsl(var(--card))] border border-[hsl(var(--border))] rounded-lg p-4 text-sm whitespace-pre-wrap">
            {event.content}
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<script define:vars={{ cardId }}>
  // Initialize expand/collapse functionality
  const btn = document.querySelector(`[data-expand-btn="${cardId}"]`);
  const content = document.querySelector(`[data-expand-content="${cardId}"]`);
  const icon = document.querySelector(`[data-expand-icon="${cardId}"]`);

  if (btn && content && icon) {
    btn.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', (!isExpanded).toString());
      content.classList.toggle('hidden');
      icon.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(180deg)';
    });
  }
</script>
