---
import PageLayout from '../../../layouts/PageLayout.astro';
import { PersonaInfo } from '../../../components/avatar/PersonaInfo';
import { ContentPillars } from '../../../components/avatar/ContentPillars';
import { VersionHistory } from '../../../components/avatar/VersionHistory';
import { ScoreRing } from '../../../components/ui/Score';
import { Badge } from '../../../components/ui/Badge';
import { getAllPersonaIds, getPersona, getPersonaHistory, getPersonaStats, getContentByPersona, getTasksByPersona } from '../../../lib/data';
import { cn, getPlatformColor, getPlatformName } from '../../../lib/utils';

export async function getStaticPaths() {
  const ids = getAllPersonaIds();
  return ids.map(id => ({ params: { id } }));
}

const { id } = Astro.params;
const persona = getPersona(id);

if (!persona) {
  return Astro.redirect('/avatars');
}

const history = getPersonaHistory(id);
const stats = getPersonaStats(id);
const contents = getContentByPersona(id);
const tasks = getTasksByPersona(id);

const gradientColors = [
  'from-blue-500 to-purple-600',
  'from-green-500 to-teal-600',
  'from-orange-500 to-red-600',
];
const gradient = gradientColors[0];
---

<PageLayout title={persona.identity.name}>
  <div class="space-y-8 animate-fade-in">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-start gap-6">
      <!-- Avatar -->
      <div class={cn('w-20 h-20 rounded-2xl bg-gradient-to-br flex items-center justify-center text-white font-bold text-2xl shadow-xl', gradient)}>
        {persona.identity.name.slice(0, 2)}
      </div>

      <!-- Info -->
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-3xl font-bold">{persona.identity.name}</h1>
          <Badge variant="outline">{persona.version}</Badge>
        </div>
        <p class="text-lg text-[hsl(var(--muted-foreground))]">{persona.identity.tagline}</p>

        <!-- Platforms -->
        <div class="flex items-center gap-2 mt-4">
          {persona.platforms.map((platform) => (
            <span class="flex items-center gap-1.5 px-2 py-1 rounded-lg bg-[hsl(var(--muted))]">
              <span class={cn('w-2 h-2 rounded-full', getPlatformColor(platform))} />
              <span class="text-sm">{getPlatformName(platform)}</span>
            </span>
          ))}
        </div>
      </div>

      <!-- Stats -->
      <div class="flex gap-6">
        <div class="text-center">
          <div class="text-3xl font-bold text-[hsl(var(--foreground))]">{stats.total_content}</div>
          <div class="text-sm text-[hsl(var(--muted-foreground))]">内容</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-500">{stats.published_content}</div>
          <div class="text-sm text-[hsl(var(--muted-foreground))]">已发布</div>
        </div>
        {stats.avg_review_score > 0 && (
          <ScoreRing score={stats.avg_review_score} size="md" label="平均分" client:load />
        )}
      </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="flex gap-2 border-b border-[hsl(var(--border))] pb-2">
      <a href={`/avatars/${id}`} class="px-4 py-2 rounded-lg bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] font-medium">
        人设详情
      </a>
      <a href={`/avatars/${id}/content`} class="px-4 py-2 rounded-lg hover:bg-[hsl(var(--accent))] text-[hsl(var(--muted-foreground))] font-medium transition-colors">
        内容 ({stats.total_content})
      </a>
      <a href={`/avatars/${id}/timeline`} class="px-4 py-2 rounded-lg hover:bg-[hsl(var(--accent))] text-[hsl(var(--muted-foreground))] font-medium transition-colors">
        时间线
      </a>
    </div>

    <!-- Content Grid -->
    <div class="grid gap-8 lg:grid-cols-2">
      <div class="space-y-6">
        <PersonaInfo persona={persona} client:load />
      </div>
      <div class="space-y-6">
        <ContentPillars pillars={persona.content_pillars} client:load />
        <VersionHistory versions={history} client:load />
      </div>
    </div>
  </div>
</PageLayout>
