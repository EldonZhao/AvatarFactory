---
import PageLayout from '../../../layouts/PageLayout.astro';
import { Timeline } from '../../../components/timeline/Timeline';
import { Badge } from '../../../components/ui/Badge';
import { getAllPersonaIds, getPersona, getPersonaStats, getTimelineEvents } from '../../../lib/data';
import { cn } from '../../../lib/utils';

export async function getStaticPaths() {
  const ids = getAllPersonaIds();
  return ids.map(id => ({ params: { id } }));
}

const { id } = Astro.params;
const persona = getPersona(id);
const base = import.meta.env.BASE_URL || '';

if (!persona) {
  return Astro.redirect(`${base}/avatars`);
}

const stats = getPersonaStats(id);
const events = getTimelineEvents(id, 100);

const gradient = 'from-blue-500 to-purple-600';
---

<PageLayout title={`${persona.identity.name} - 时间线`}>
  <div class="space-y-8 animate-fade-in">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-start gap-6">
      <!-- Avatar -->
      <a href={`${base}/avatars/${id}`} class={cn('w-16 h-16 rounded-xl bg-gradient-to-br flex items-center justify-center text-white font-bold text-xl shadow-lg hover:shadow-xl transition-shadow', gradient)}>
        {persona.identity.name.slice(0, 2)}
      </a>

      <!-- Info -->
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-1">
          <h1 class="text-2xl font-bold">{persona.identity.name}</h1>
          <Badge variant="outline">{persona.version}</Badge>
        </div>
        <p class="text-[hsl(var(--muted-foreground))]">{persona.identity.tagline}</p>
      </div>

      <!-- Event Count -->
      <div class="text-center">
        <div class="text-2xl font-bold">{events.length}</div>
        <div class="text-xs text-[hsl(var(--muted-foreground))]">事件</div>
      </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="flex gap-2 border-b border-[hsl(var(--border))] pb-2">
      <a href={`${base}/avatars/${id}`} class="px-4 py-2 rounded-lg hover:bg-[hsl(var(--accent))] text-[hsl(var(--muted-foreground))] font-medium transition-colors">
        人设详情
      </a>
      <a href={`${base}/avatars/${id}/content`} class="px-4 py-2 rounded-lg hover:bg-[hsl(var(--accent))] text-[hsl(var(--muted-foreground))] font-medium transition-colors">
        内容 ({stats.total_content})
      </a>
      <a href={`${base}/avatars/${id}/timeline`} class="px-4 py-2 rounded-lg bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] font-medium">
        时间线
      </a>
    </div>

    <!-- Timeline -->
    <div class="max-w-3xl">
      <Timeline events={events} title={`${persona.identity.name} 的成长历程`} client:load />
    </div>
  </div>
</PageLayout>
