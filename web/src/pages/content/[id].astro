---
import PageLayout from '../../layouts/PageLayout.astro';
import { MarkdownRenderer } from '../../components/content/MarkdownRenderer';
import { ReviewScore, ReviewDimensionDetail } from '../../components/content/ReviewScore';
import { Badge } from '../../components/ui/Badge';
import { Card, CardHeader, CardTitle, CardContent } from '../../components/ui/Card';
import { getAllContent, getContent, getReview, getPersona } from '../../lib/data';
import { formatDate, getPlatformColor, getPlatformName, cn } from '../../lib/utils';

export async function getStaticPaths() {
  const contents = getAllContent();
  return contents.map(c => ({ params: { id: c.id } }));
}

const { id } = Astro.params;
const content = getContent(id);

if (!content) {
  return Astro.redirect('/');
}

const review = getReview(id);
const persona = getPersona(content.persona_id);
---

<PageLayout title={content.title}>
  <div class="space-y-8 animate-fade-in">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-[hsl(var(--muted-foreground))]">
      <a href="/" class="hover:text-[hsl(var(--foreground))]">首页</a>
      <span>/</span>
      {persona && (
        <>
          <a href={`/avatars/${persona.id}`} class="hover:text-[hsl(var(--foreground))]">{persona.identity.name}</a>
          <span>/</span>
        </>
      )}
      <span class="text-[hsl(var(--foreground))]">内容</span>
    </nav>

    <!-- Header -->
    <div>
      <div class="flex items-center gap-3 mb-3">
        <span class={cn('w-3 h-3 rounded-full', getPlatformColor(content.platform))} />
        <span class="text-sm text-[hsl(var(--muted-foreground))]">{getPlatformName(content.platform)}</span>
        <Badge variant={content.status === 'published' ? 'success' : 'secondary'}>
          {content.status === 'published' ? '已发布' : '草稿'}
        </Badge>
        <span class="text-sm text-[hsl(var(--muted-foreground))]">
          {formatDate(content.created_at, 'full')}
        </span>
      </div>
      <h1 class="text-3xl font-bold mb-4">{content.title}</h1>

      <div class="flex flex-wrap gap-2 mb-4">
        {content.tags.map(tag => (
          <Badge variant="outline">{tag}</Badge>
        ))}
      </div>

      {persona && (
        <a href={`/avatars/${persona.id}`} class="inline-flex items-center gap-2 p-2 rounded-lg bg-[hsl(var(--muted))] hover:bg-[hsl(var(--accent))] transition-colors">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white text-sm font-bold">
            {persona.identity.name.slice(0, 2)}
          </div>
          <div>
            <div class="text-sm font-medium">{persona.identity.name}</div>
            <div class="text-xs text-[hsl(var(--muted-foreground))]">{content.pillar}</div>
          </div>
        </a>
      )}
    </div>

    <!-- Main Content -->
    <div class="grid gap-8 lg:grid-cols-3">
      <!-- Content Body -->
      <div class="lg:col-span-2">
        <Card>
          <CardContent className="p-6 lg:p-8">
            <MarkdownRenderer content={content.body} client:load />
          </CardContent>
        </Card>

        {/* Structure Info */}
        {content.structure && (
          <Card className="mt-6">
            <CardHeader>
              <CardTitle>内容结构</CardTitle>
            </CardHeader>
            <CardContent>
              <div class="space-y-3">
                <div>
                  <span class="text-sm text-[hsl(var(--muted-foreground))]">段落结构:</span>
                  <ul class="mt-1 space-y-1">
                    {content.structure.sections.map((section, i) => (
                      <li class="text-sm flex items-start gap-2">
                        <span class="text-[hsl(var(--primary))]">{i + 1}.</span>
                        <span>{section}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                {content.structure.style_constraints && Object.entries(content.structure.style_constraints).map(([key, value]) => (
                  <div>
                    <span class="text-sm text-[hsl(var(--muted-foreground))]">{key}:</span>
                    <p class="text-sm mt-0.5">{value}</p>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        )}
      </div>

      <!-- Sidebar: Review -->
      <div class="space-y-6">
        {review ? (
          <>
            <ReviewScore review={review} client:load />

            <ReviewDimensionDetail
              title="人设一致性"
              dimension={review.persona_consistency}
              client:load
            />

            <ReviewDimensionDetail
              title="平台适配度"
              dimension={review.platform_fit}
              client:load
            />

            <ReviewDimensionDetail
              title="互动潜力"
              dimension={review.engagement_potential}
              client:load
            />
          </>
        ) : (
          <Card>
            <CardContent className="p-6 text-center text-[hsl(var(--muted-foreground))]">
              <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p>暂无审核报告</p>
            </CardContent>
          </Card>
        )}
      </div>
    </div>
  </div>
</PageLayout>
