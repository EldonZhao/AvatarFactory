---
export const prerender = false;

import PageLayout from '../layouts/PageLayout.astro';
import { StatsOverview } from '../components/dashboard/StatsOverview';
import { AvatarCard } from '../components/avatar/AvatarCard';
import { ContentCard } from '../components/content/ContentCard';
import { Timeline } from '../components/timeline/Timeline';
import { TaskList } from '../components/scheduler/TaskCard';
import { getAllPersonas, getPersonaStats, getRecentContent, getGlobalStats, getTimelineEvents, getActiveTasks } from '../lib/data';

const personas = await getAllPersonas();
const personasWithStats = await Promise.all(
  personas.slice(0, 6).map(async (p) => ({
    persona: p,
    stats: await getPersonaStats(p.id)
  }))
);

const recentContent = await getRecentContent(6);
const globalStats = await getGlobalStats();
const timelineEvents = await getTimelineEvents(undefined, 10);
const activeTasks = (await getActiveTasks()).slice(0, 5);
const base = import.meta.env.BASE_URL || '';
---

<PageLayout title="Dashboard">
  <div class="space-y-8 animate-fade-in">
    <!-- Header -->
    <div>
      <h1 class="text-3xl font-bold gradient-text">Avatar Monitor</h1>
      <p class="text-[hsl(var(--muted-foreground))] mt-1">Monitor Avatar status and content in real-time</p>
    </div>

    <!-- Stats Overview -->
    <StatsOverview stats={globalStats} client:load />

    <!-- Main Grid -->
    <div class="grid gap-8 lg:grid-cols-3">
      <!-- Left Column: Avatars & Content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Avatars Section -->
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold">最近的 Avatar</h2>
            <a href={`${base}/avatars`} class="text-sm text-[hsl(var(--primary))] hover:underline">查看全部 →</a>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {personasWithStats.map(({ persona, stats }, index) => (
              <AvatarCard persona={persona} stats={stats} index={index} client:load />
            ))}
          </div>
        </section>

        <!-- Recent Content Section -->
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold">最新内容</h2>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {recentContent.map((content, index) => (
              <ContentCard content={content} index={index} client:load />
            ))}
          </div>
        </section>
      </div>

      <!-- Right Column: Timeline & Tasks -->
      <div class="space-y-8">
        <Timeline events={timelineEvents} title="最近动态" maxItems={8} client:load />
        <TaskList tasks={activeTasks} title="活跃任务" client:load />
      </div>
    </div>
  </div>
</PageLayout>
