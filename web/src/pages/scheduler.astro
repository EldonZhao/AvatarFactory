---
import PageLayout from '../layouts/PageLayout.astro';
import { TaskCard } from '../components/scheduler/TaskCard';
import { SchedulerStats } from '../components/scheduler/SchedulerStats';
import { Badge } from '../components/ui/Badge';
import { Card, CardHeader, CardTitle, CardContent } from '../components/ui/Card';
import { getAllTasks, getTaskStats } from '../lib/data';

const tasks = getAllTasks();
const stats = getTaskStats();

const tasksByType: Record<string, typeof tasks> = {};
for (const task of tasks) {
  if (!tasksByType[task.task_type]) {
    tasksByType[task.task_type] = [];
  }
  tasksByType[task.task_type].push(task);
}

const typeNames: Record<string, string> = {
  discovery: '发现任务',
  content: '内容任务',
  trend_scan: '趋势扫描',
  persona_recommendation: '人设推荐',
};
---

<PageLayout title="调度任务">
  <div class="space-y-8 animate-fade-in">
    <!-- Header -->
    <div>
      <h1 class="text-3xl font-bold">调度任务</h1>
      <p class="text-[hsl(var(--muted-foreground))] mt-1">管理 Avatar 的自动化任务</p>
    </div>

    <!-- Stats -->
    <SchedulerStats
      total={stats.total}
      active={stats.active}
      successRate={stats.successRate}
      typeCount={Object.keys(stats.byType).length}
      client:load
    />

    <!-- Tasks by Type -->
    <div class="space-y-8">
      {Object.entries(tasksByType).map(([type, typeTasks]) => (
        <section>
          <div class="flex items-center gap-3 mb-4">
            <h2 class="text-xl font-semibold">{typeNames[type] || type}</h2>
            <Badge variant="secondary" client:load>{typeTasks.length}</Badge>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {typeTasks.map((task, index) => (
              <TaskCard task={task} index={index} client:load />
            ))}
          </div>
        </section>
      ))}
    </div>

    {tasks.length === 0 && (
      <div class="text-center py-16 text-[hsl(var(--muted-foreground))]">
        <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-lg">暂无调度任务</p>
        <p class="text-sm mt-1">在 Dashboard 中设置定时任务</p>
      </div>
    )}
  </div>
</PageLayout>
